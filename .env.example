# =============================================================================
# WhatsApp Bulk Messaging CRM — Environment Variables
# Copy this file to .env and fill in all values
# =============================================================================

# --- App ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
APP_BASE_URL=http://localhost:4000

# --- Database (Neon DB - serverless PostgreSQL) ---
# Get from: https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/wacrm?sslmode=require

# --- Redis (Upstash - serverless Redis) ---
# Get from: https://console.upstash.com
REDIS_URL=rediss://default:password@us1-xxx.upstash.io:6379

# --- JWT ---
JWT_SECRET=change_this_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Encryption (for WhatsApp access tokens at rest) ---
# Must be exactly 32 bytes (64 hex chars)
ENCRYPTION_KEY=change_this_to_a_random_64_char_hex_string_for_aes256

# --- Stripe ---
# Get from: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SETUP_PRICE_ID=price_setup_49usd
STRIPE_MONTHLY_PRICE_ID=price_monthly_29usd

# --- WhatsApp Meta Cloud API ---
# Default Meta Graph API version
META_API_VERSION=v18.0
META_GRAPH_URL=https://graph.facebook.com
# Per-number tokens are stored encrypted in DB; these are fallback defaults
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=billy777_verify

# --- Single Owner Login ---
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=ReplaceThisWithAStrongPassword123!
OWNER_FULL_NAME=Billy777 Owner

# --- Frontend (for Docker build args) ---
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
